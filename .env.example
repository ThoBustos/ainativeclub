# Supabase - Get from Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=        # Project URL (https://xxx.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=   # anon/public key (safe for browser)
SUPABASE_SERVICE_ROLE_KEY=       # service_role key (server-only, never expose)

# Resend - Get from resend.com/api-keys
RESEND_API_KEY=                  # API key for sending emails
RESEND_FROM_EMAIL=notifications@ainativeclub.com  # "From" address (must be verified domain)
NOTIFICATION_EMAIL=              # Your email - receives alerts when someone applies

# Anthropic - Claude API for portal chat
ANTHROPIC_API_KEY=               # Get from console.anthropic.com

# Upstash Redis - Rate limiting (optional, configure for production)
# Create a Redis database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=           # Redis REST URL
UPSTASH_REDIS_REST_TOKEN=         # Redis REST token

# Twilio WhatsApp (required for WhatsApp feature)
# Configure at twilio.com/console — enable WhatsApp on your number
TWILIO_ACCOUNT_SID=               # Account SID (starts with AC...)
TWILIO_AUTH_TOKEN=                 # Auth token (keep secret)
TWILIO_WHATSAPP_NUMBER=            # Your WhatsApp-enabled number, e.g. +14155238886
# Webhook URL to configure in Twilio: https://app.ainativeclub.com/api/whatsapp

# Inngest (required for WhatsApp async processing in production)
# Create a free account at app.inngest.com, then grab keys from your app settings
INNGEST_EVENT_KEY=                 # Event key (used to send events)
INNGEST_SIGNING_KEY=               # Signing key (used to verify requests from Inngest)

# Sentry - Error reporting (optional, configure for production)
# Run: npx @sentry/wizard@latest -i nextjs, or get DSN from sentry.io
SENTRY_DSN=                       # Sentry DSN (server)
NEXT_PUBLIC_SENTRY_DSN=           # Sentry DSN (client)
